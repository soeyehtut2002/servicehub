# Frontend environment for Render.com deployment
# Set this in Render → Static Site → Environment Variables

# Replace with your Render backend URL after creating the Web Service
VITE_API_URL=https://your-backend-name.onrender.com/api

# Replace with your Render backend URL (no /api suffix) for file uploads
VITE_BASE_URL=https://your-backend-name.onrender.com
